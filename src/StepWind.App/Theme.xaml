<!--
  StepWind design system — the app's own visual identity (not the OS theme).

  An opaque, designed dark surface in the style of modern custom-branded Windows apps
  (NVIDIA App, Discord): deep slate layers, indigo→cyan brand accents, kind-colored
  operation rails. Built ON TOP of accessible control plumbing — templates below restyle
  visuals only and keep keyboard focus, hit targets, and automation behavior intact.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════ Motion primitives ═══════════════════════ -->
  <!-- Compositor-only (opacity + transform); short with a cubic ease-out. -->

  <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>

  <!-- Rows fade + slide in on load; because containers realize top-to-bottom this reads as a
       gentle cascade without any per-item delay bookkeeping. Targets the template's "Chrome"
       border (which carries the TranslateTransform) — resolved per-instance namescope. -->
  <Storyboard x:Key="RowEnter">
    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Opacity"
                     From="0" To="1" Duration="0:0:0.28" EasingFunction="{StaticResource EaseOut}"/>
    <DoubleAnimation Storyboard.TargetName="Chrome"
                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                     From="14" To="0" Duration="0:0:0.30" EasingFunction="{StaticResource EaseOut}"/>
  </Storyboard>

  <!-- ═══════════════════════ Palette ═══════════════════════ -->

  <!-- Surfaces: window → raised → card → hover, each a step lighter. -->
  <Color x:Key="C.Bg">#0A0C10</Color>
  <Color x:Key="C.Rail">#0D1016</Color>
  <Color x:Key="C.Card">#12151D</Color>
  <Color x:Key="C.CardHover">#171B25</Color>
  <Color x:Key="C.Inset">#0E1118</Color>
  <Color x:Key="C.Stroke">#222836</Color>
  <Color x:Key="C.StrokeSoft">#1A1F2A</Color>

  <Color x:Key="C.Text">#E9ECF3</Color>
  <Color x:Key="C.Text2">#9AA3B7</Color>
  <Color x:Key="C.Text3">#646E82</Color>

  <Color x:Key="C.Indigo">#6366F1</Color>
  <Color x:Key="C.IndigoHover">#787BF5</Color>
  <Color x:Key="C.IndigoPress">#5457E0</Color>
  <Color x:Key="C.Cyan">#22D3EE</Color>

  <SolidColorBrush x:Key="SW.Bg" Color="{StaticResource C.Bg}"/>
  <SolidColorBrush x:Key="SW.Rail" Color="{StaticResource C.Rail}"/>
  <SolidColorBrush x:Key="SW.Card" Color="{StaticResource C.Card}"/>
  <SolidColorBrush x:Key="SW.CardHover" Color="{StaticResource C.CardHover}"/>
  <SolidColorBrush x:Key="SW.Inset" Color="{StaticResource C.Inset}"/>
  <SolidColorBrush x:Key="SW.Stroke" Color="{StaticResource C.Stroke}"/>
  <SolidColorBrush x:Key="SW.StrokeSoft" Color="{StaticResource C.StrokeSoft}"/>

  <SolidColorBrush x:Key="SW.Text" Color="{StaticResource C.Text}"/>
  <SolidColorBrush x:Key="SW.Text2" Color="{StaticResource C.Text2}"/>
  <SolidColorBrush x:Key="SW.Text3" Color="{StaticResource C.Text3}"/>

  <SolidColorBrush x:Key="SW.Indigo" Color="{StaticResource C.Indigo}"/>
  <SolidColorBrush x:Key="SW.IndigoHover" Color="{StaticResource C.IndigoHover}"/>
  <SolidColorBrush x:Key="SW.IndigoPress" Color="{StaticResource C.IndigoPress}"/>
  <SolidColorBrush x:Key="SW.Cyan" Color="{StaticResource C.Cyan}"/>
  <SolidColorBrush x:Key="SW.IndigoFaint" Color="#266366F1"/>
  <SolidColorBrush x:Key="SW.CyanFaint" Color="#1F22D3EE"/>

  <!-- Brand gradient (the icon's indigo → cyan). -->
  <LinearGradientBrush x:Key="SW.BrandGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#6366F1" Offset="0"/>
    <GradientStop Color="#22D3EE" Offset="1"/>
  </LinearGradientBrush>

  <!-- Operation kinds: each gets a signature color used on rails, chips, and dots. -->
  <SolidColorBrush x:Key="SW.Kind.Create" Color="#34D399"/>
  <SolidColorBrush x:Key="SW.Kind.Modify" Color="#818CF8"/>
  <SolidColorBrush x:Key="SW.Kind.Move" Color="#FBBF24"/>
  <SolidColorBrush x:Key="SW.Kind.Rename" Color="#C084FC"/>
  <SolidColorBrush x:Key="SW.Kind.Delete" Color="#FB7185"/>
  <SolidColorBrush x:Key="SW.Kind.Create.Faint" Color="#2634D399"/>
  <SolidColorBrush x:Key="SW.Kind.Modify.Faint" Color="#26818CF8"/>
  <SolidColorBrush x:Key="SW.Kind.Move.Faint" Color="#26FBBF24"/>
  <SolidColorBrush x:Key="SW.Kind.Rename.Faint" Color="#26C084FC"/>
  <SolidColorBrush x:Key="SW.Kind.Delete.Faint" Color="#26FB7185"/>

  <SolidColorBrush x:Key="SW.Danger" Color="#FB7185"/>
  <SolidColorBrush x:Key="SW.Ok" Color="#34D399"/>

  <!-- ═══════════════════════ Typography ═══════════════════════ -->

  <FontFamily x:Key="SW.Font">Segoe UI Variable Display, Segoe UI</FontFamily>
  <FontFamily x:Key="SW.Font.Text">Segoe UI Variable Text, Segoe UI</FontFamily>
  <FontFamily x:Key="SW.Font.Mono">Cascadia Mono, Consolas</FontFamily>

  <Style x:Key="SW.PageTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource SW.Font}"/>
    <Setter Property="FontSize" Value="22"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
  </Style>

  <Style x:Key="SW.PageSub" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text2}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="SW.SectionLabel" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text3}"/>
    <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
  </Style>

  <!-- ═══════════════════════ Focus visual ═══════════════════════ -->

  <Style x:Key="SW.FocusVisual">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Border BorderBrush="{StaticResource SW.Cyan}" BorderThickness="1.5"
                  CornerRadius="8" Margin="-3" SnapsToDevicePixels="True"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Buttons ═══════════════════════ -->

  <Style x:Key="SW.Button" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource SW.FocusVisual}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome" BorderThickness="1" CornerRadius="8"
                  Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                  RenderTransformOrigin="0.5,0.5">
            <Border.Background><SolidColorBrush Color="#171B25"/></Border.Background>
            <Border.BorderBrush><SolidColorBrush Color="#222836"/></Border.BorderBrush>
            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color"
                                    To="#1E2432" Duration="0:0:0.15"/>
                    <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="BorderBrush.Color"
                                    To="#2E3648" Duration="0:0:0.15"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color"
                                    To="#171B25" Duration="0:0:0.20"/>
                    <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="BorderBrush.Color"
                                    To="#222836" Duration="0:0:0.20"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.96" Duration="0:0:0.08"/>
                    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.96" Duration="0:0:0.08"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.14" EasingFunction="{StaticResource EaseOut}"/>
                    <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.14" EasingFunction="{StaticResource EaseOut}"/>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SW.Button.Primary" TargetType="Button" BasedOn="{StaticResource SW.Button}">
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome" CornerRadius="8" Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True" RenderTransformOrigin="0.5,0.5">
            <Border.Background><SolidColorBrush Color="#6366F1"/></Border.Background>
            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#787BF5" Duration="0:0:0.15"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#6366F1" Duration="0:0:0.20"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#5457E0" Duration="0:0:0.08"/>
                  <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.96" Duration="0:0:0.08"/>
                  <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.96" Duration="0:0:0.08"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.14" EasingFunction="{StaticResource EaseOut}"/>
                  <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.14" EasingFunction="{StaticResource EaseOut}"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SW.Button.Ghost" TargetType="Button" BasedOn="{StaticResource SW.Button}">
    <Setter Property="Foreground" Value="{StaticResource SW.Text2}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome" CornerRadius="8" Padding="{TemplateBinding Padding}">
            <Border.Background><SolidColorBrush Color="Transparent"/></Border.Background>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#161B26" Duration="0:0:0.15"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#00161B26" Duration="0:0:0.20"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SW.Button.Danger" TargetType="Button" BasedOn="{StaticResource SW.Button}">
    <Setter Property="Foreground" Value="{StaticResource SW.Danger}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome" BorderThickness="1" CornerRadius="8"
                  Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                  RenderTransformOrigin="0.5,0.5">
            <Border.Background><SolidColorBrush Color="#14FB7185"/></Border.Background>
            <Border.BorderBrush><SolidColorBrush Color="#33FB7185"/></Border.BorderBrush>
            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#24FB7185" Duration="0:0:0.15"/>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="BorderBrush.Color" To="#55FB7185" Duration="0:0:0.15"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#14FB7185" Duration="0:0:0.20"/>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="BorderBrush.Color" To="#33FB7185" Duration="0:0:0.20"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.96" Duration="0:0:0.08"/>
                  <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.96" Duration="0:0:0.08"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.14" EasingFunction="{StaticResource EaseOut}"/>
                  <DoubleAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.14" EasingFunction="{StaticResource EaseOut}"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Nav rail item ═══════════════════════ -->

  <Style x:Key="SW.NavItem" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{StaticResource SW.Text2}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource SW.FocusVisual}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Grid Background="Transparent" Margin="10,1">
            <Border x:Name="Chrome" CornerRadius="8" Padding="12,9">
              <Border.Background><SolidColorBrush Color="Transparent"/></Border.Background>
              <ContentPresenter VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <Border x:Name="Indicator" Width="3" Height="16" CornerRadius="2"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    Background="{StaticResource SW.BrandGradient}" Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
              <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="0.2"/></Border.RenderTransform>
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#141924" Duration="0:0:0.15"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#00141924" Duration="0:0:0.20"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
              <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
              <Trigger.EnterActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#181E2B" Duration="0:0:0.18"/>
                  <!-- The active indicator grows in from a sliver, giving the rail a satisfying selection cue. -->
                  <DoubleAnimation Storyboard.TargetName="Indicator" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                  <DoubleAnimation Storyboard.TargetName="Indicator" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
                </Storyboard></BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard><Storyboard>
                  <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#00181E2B" Duration="0:0:0.20"/>
                  <DoubleAnimation Storyboard.TargetName="Indicator" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.14"/>
                  <DoubleAnimation Storyboard.TargetName="Indicator" Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.2" Duration="0:0:0.14"/>
                </Storyboard></BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Filter chip ═══════════════════════ -->

  <Style x:Key="SW.Chip" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{StaticResource SW.Text2}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource SW.FocusVisual}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="Chrome" CornerRadius="14" Padding="12,5" Background="Transparent"
                  BorderThickness="1" BorderBrush="{StaticResource SW.StrokeSoft}">
            <ContentPresenter VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#151A25"/>
              <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SW.IndigoFaint}"/>
              <Setter TargetName="Chrome" Property="BorderBrush" Value="#556366F1"/>
              <Setter Property="Foreground" Value="#B9BBFF"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Cards ═══════════════════════ -->

  <Style x:Key="SW.CardStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource SW.Card}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SW.StrokeSoft}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
  </Style>

  <!-- Interactive card: lifts slightly and brightens on hover (transform + color only). -->
  <Style x:Key="SW.CardStyle.Hover" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource SW.Card}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SW.StrokeSoft}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    <Setter Property="RenderTransform">
      <Setter.Value><TranslateTransform Y="0"/></Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{StaticResource SW.CardHover}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SW.Stroke}"/>
        <Trigger.EnterActions>
          <BeginStoryboard><Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             To="-3" Duration="0:0:0.16" EasingFunction="{StaticResource EaseOut}"/>
          </Storyboard></BeginStoryboard>
        </Trigger.EnterActions>
        <Trigger.ExitActions>
          <BeginStoryboard><Storyboard>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.22" EasingFunction="{StaticResource EaseOut}"/>
          </Storyboard></BeginStoryboard>
        </Trigger.ExitActions>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- Slow, gentle pulse ring for the "protection active" status dot. -->
  <Storyboard x:Key="StatusPulse" RepeatBehavior="Forever">
    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.9" To="0.35"
                     Duration="0:0:1.4" AutoReverse="True" EasingFunction="{StaticResource EaseOut}"/>
  </Storyboard>

  <!-- ═══════════════════════ Search / text input ═══════════════════════ -->

  <Style x:Key="SW.TextBox" TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
    <Setter Property="CaretBrush" Value="{StaticResource SW.Cyan}"/>
    <Setter Property="Background" Value="{StaticResource SW.Inset}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SW.StrokeSoft}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Padding" Value="12,7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                  CornerRadius="8">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                          VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SW.Stroke}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SW.Indigo}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Scrollbar (thin, unobtrusive) ═══════════════════════ -->

  <Style x:Key="SW.ScrollThumb" TargetType="Thumb">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border Background="#2A3140" CornerRadius="3" Margin="1"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Width" Value="7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid Background="Transparent">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
              <Track.Thumb>
                <Thumb Style="{StaticResource SW.ScrollThumb}"/>
              </Track.Thumb>
            </Track>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
              <Setter Property="Height" Value="7"/>
              <Setter Property="Width" Value="Auto"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ List container (no chrome rows) ═══════════════════════ -->

  <Style x:Key="SW.List" TargetType="ListBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
    <Setter Property="ItemContainerStyle">
      <Setter.Value>
        <Style TargetType="ListBoxItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
          <Setter Property="Padding" Value="0"/>
          <Setter Property="FocusVisualStyle" Value="{StaticResource SW.FocusVisual}"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="Chrome" CornerRadius="10" Padding="{TemplateBinding Padding}"
                        RenderTransformOrigin="0,0.5">
                  <Border.Background><SolidColorBrush Color="Transparent"/></Border.Background>
                  <Border.RenderTransform><TranslateTransform X="0" Y="0"/></Border.RenderTransform>
                  <ContentPresenter/>
                </Border>
                <ControlTemplate.Triggers>
                  <!-- Row appears with a small fade+slide (top-to-bottom realization = cascade). -->
                  <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource RowEnter}"/>
                  </EventTrigger>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                      <BeginStoryboard><Storyboard>
                        <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#12161F" Duration="0:0:0.13"/>
                      </Storyboard></BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                      <BeginStoryboard><Storyboard>
                        <ColorAnimation Storyboard.TargetName="Chrome" Storyboard.TargetProperty="Background.Color" To="#0012161F" Duration="0:0:0.18"/>
                      </Storyboard></BeginStoryboard>
                    </Trigger.ExitActions>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#1A2030"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Tooltip ═══════════════════════ -->

  <Style TargetType="ToolTip">
    <Setter Property="Background" Value="#1A1F2C"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SW.Stroke}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToolTip">
          <Border Background="{TemplateBinding Background}" BorderThickness="1"
                  BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="8" Padding="10,6">
            <ContentPresenter/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
