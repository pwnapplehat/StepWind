<!--
  StepWind design system — the app's own visual identity (not the OS theme).

  An opaque, designed dark surface in the style of modern custom-branded Windows apps
  (NVIDIA App, Discord): deep slate layers, indigo→cyan brand accents, kind-colored
  operation rails. Built ON TOP of accessible control plumbing — templates below restyle
  visuals only and keep keyboard focus, hit targets, and automation behavior intact.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════ Palette ═══════════════════════ -->

  <!-- Surfaces: window → raised → card → hover, each a step lighter. -->
  <Color x:Key="C.Bg">#0A0C10</Color>
  <Color x:Key="C.Rail">#0D1016</Color>
  <Color x:Key="C.Card">#12151D</Color>
  <Color x:Key="C.CardHover">#171B25</Color>
  <Color x:Key="C.Inset">#0E1118</Color>
  <Color x:Key="C.Stroke">#222836</Color>
  <Color x:Key="C.StrokeSoft">#1A1F2A</Color>

  <Color x:Key="C.Text">#E9ECF3</Color>
  <Color x:Key="C.Text2">#9AA3B7</Color>
  <Color x:Key="C.Text3">#646E82</Color>

  <Color x:Key="C.Indigo">#6366F1</Color>
  <Color x:Key="C.IndigoHover">#787BF5</Color>
  <Color x:Key="C.IndigoPress">#5457E0</Color>
  <Color x:Key="C.Cyan">#22D3EE</Color>

  <SolidColorBrush x:Key="SW.Bg" Color="{StaticResource C.Bg}"/>
  <SolidColorBrush x:Key="SW.Rail" Color="{StaticResource C.Rail}"/>
  <SolidColorBrush x:Key="SW.Card" Color="{StaticResource C.Card}"/>
  <SolidColorBrush x:Key="SW.CardHover" Color="{StaticResource C.CardHover}"/>
  <SolidColorBrush x:Key="SW.Inset" Color="{StaticResource C.Inset}"/>
  <SolidColorBrush x:Key="SW.Stroke" Color="{StaticResource C.Stroke}"/>
  <SolidColorBrush x:Key="SW.StrokeSoft" Color="{StaticResource C.StrokeSoft}"/>

  <SolidColorBrush x:Key="SW.Text" Color="{StaticResource C.Text}"/>
  <SolidColorBrush x:Key="SW.Text2" Color="{StaticResource C.Text2}"/>
  <SolidColorBrush x:Key="SW.Text3" Color="{StaticResource C.Text3}"/>

  <SolidColorBrush x:Key="SW.Indigo" Color="{StaticResource C.Indigo}"/>
  <SolidColorBrush x:Key="SW.IndigoHover" Color="{StaticResource C.IndigoHover}"/>
  <SolidColorBrush x:Key="SW.IndigoPress" Color="{StaticResource C.IndigoPress}"/>
  <SolidColorBrush x:Key="SW.Cyan" Color="{StaticResource C.Cyan}"/>
  <SolidColorBrush x:Key="SW.IndigoFaint" Color="#266366F1"/>
  <SolidColorBrush x:Key="SW.CyanFaint" Color="#1F22D3EE"/>

  <!-- Brand gradient (the icon's indigo → cyan). -->
  <LinearGradientBrush x:Key="SW.BrandGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#6366F1" Offset="0"/>
    <GradientStop Color="#22D3EE" Offset="1"/>
  </LinearGradientBrush>

  <!-- Operation kinds: each gets a signature color used on rails, chips, and dots. -->
  <SolidColorBrush x:Key="SW.Kind.Create" Color="#34D399"/>
  <SolidColorBrush x:Key="SW.Kind.Modify" Color="#818CF8"/>
  <SolidColorBrush x:Key="SW.Kind.Move" Color="#FBBF24"/>
  <SolidColorBrush x:Key="SW.Kind.Rename" Color="#C084FC"/>
  <SolidColorBrush x:Key="SW.Kind.Delete" Color="#FB7185"/>
  <SolidColorBrush x:Key="SW.Kind.Create.Faint" Color="#2634D399"/>
  <SolidColorBrush x:Key="SW.Kind.Modify.Faint" Color="#26818CF8"/>
  <SolidColorBrush x:Key="SW.Kind.Move.Faint" Color="#26FBBF24"/>
  <SolidColorBrush x:Key="SW.Kind.Rename.Faint" Color="#26C084FC"/>
  <SolidColorBrush x:Key="SW.Kind.Delete.Faint" Color="#26FB7185"/>

  <SolidColorBrush x:Key="SW.Danger" Color="#FB7185"/>
  <SolidColorBrush x:Key="SW.Ok" Color="#34D399"/>

  <!-- ═══════════════════════ Typography ═══════════════════════ -->

  <FontFamily x:Key="SW.Font">Segoe UI Variable Display, Segoe UI</FontFamily>
  <FontFamily x:Key="SW.Font.Text">Segoe UI Variable Text, Segoe UI</FontFamily>
  <FontFamily x:Key="SW.Font.Mono">Cascadia Mono, Consolas</FontFamily>

  <Style x:Key="SW.PageTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource SW.Font}"/>
    <Setter Property="FontSize" Value="22"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
  </Style>

  <Style x:Key="SW.PageSub" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text2}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="SW.SectionLabel" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text3}"/>
    <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
  </Style>

  <!-- ═══════════════════════ Focus visual ═══════════════════════ -->

  <Style x:Key="SW.FocusVisual">
    <Setter Property="Control.Template">
      <Setter.Value>
        <ControlTemplate>
          <Border BorderBrush="{StaticResource SW.Cyan}" BorderThickness="1.5"
                  CornerRadius="8" Margin="-3" SnapsToDevicePixels="True"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Buttons ═══════════════════════ -->

  <Style x:Key="SW.Button" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
    <Setter Property="Background" Value="{StaticResource SW.CardHover}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SW.Stroke}"/>
    <Setter Property="Padding" Value="14,7"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource SW.FocusVisual}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                  CornerRadius="8" Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#1E2432"/>
              <Setter TargetName="Chrome" Property="BorderBrush" Value="#2E3648"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#141821"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SW.Button.Primary" TargetType="Button" BasedOn="{StaticResource SW.Button}">
    <Setter Property="Background" Value="{StaticResource SW.Indigo}"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground" Value="#FFFFFF"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                  CornerRadius="8" Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SW.IndigoHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SW.IndigoPress}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SW.Button.Ghost" TargetType="Button" BasedOn="{StaticResource SW.Button}">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text2}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                  CornerRadius="8" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#161B26"/>
              <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#121620"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SW.Button.Danger" TargetType="Button" BasedOn="{StaticResource SW.Button}">
    <Setter Property="Foreground" Value="{StaticResource SW.Danger}"/>
    <Setter Property="BorderBrush" Value="#33FB7185"/>
    <Setter Property="Background" Value="#14FB7185"/>
  </Style>

  <!-- ═══════════════════════ Nav rail item ═══════════════════════ -->

  <Style x:Key="SW.NavItem" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{StaticResource SW.Text2}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource SW.FocusVisual}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Grid Background="Transparent" Margin="10,1">
            <Border x:Name="Chrome" CornerRadius="8" Background="Transparent" Padding="12,9">
              <ContentPresenter VerticalAlignment="Center"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
            </Border>
            <Border x:Name="Indicator" Width="3" Height="16" CornerRadius="2"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    Background="{StaticResource SW.BrandGradient}" Opacity="0"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#141924"/>
              <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#181E2B"/>
              <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
              <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Filter chip ═══════════════════════ -->

  <Style x:Key="SW.Chip" TargetType="RadioButton">
    <Setter Property="Foreground" Value="{StaticResource SW.Text2}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{StaticResource SW.FocusVisual}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Border x:Name="Chrome" CornerRadius="14" Padding="12,5" Background="Transparent"
                  BorderThickness="1" BorderBrush="{StaticResource SW.StrokeSoft}">
            <ContentPresenter VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="#151A25"/>
              <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SW.IndigoFaint}"/>
              <Setter TargetName="Chrome" Property="BorderBrush" Value="#556366F1"/>
              <Setter Property="Foreground" Value="#B9BBFF"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Cards ═══════════════════════ -->

  <Style x:Key="SW.CardStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource SW.Card}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SW.StrokeSoft}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="12"/>
  </Style>

  <Style x:Key="SW.CardStyle.Hover" TargetType="Border" BasedOn="{StaticResource SW.CardStyle}">
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{StaticResource SW.CardHover}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SW.Stroke}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ═══════════════════════ Search / text input ═══════════════════════ -->

  <Style x:Key="SW.TextBox" TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
    <Setter Property="CaretBrush" Value="{StaticResource SW.Cyan}"/>
    <Setter Property="Background" Value="{StaticResource SW.Inset}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SW.StrokeSoft}"/>
    <Setter Property="FontSize" Value="12.5"/>
    <Setter Property="Padding" Value="12,7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                  CornerRadius="8">
            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                          VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SW.Stroke}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SW.Indigo}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Scrollbar (thin, unobtrusive) ═══════════════════════ -->

  <Style x:Key="SW.ScrollThumb" TargetType="Thumb">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border Background="#2A3140" CornerRadius="3" Margin="1"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Width" Value="7"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ScrollBar">
          <Grid Background="Transparent">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
              <Track.Thumb>
                <Thumb Style="{StaticResource SW.ScrollThumb}"/>
              </Track.Thumb>
            </Track>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
              <Setter Property="Height" Value="7"/>
              <Setter Property="Width" Value="Auto"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ List container (no chrome rows) ═══════════════════════ -->

  <Style x:Key="SW.List" TargetType="ListBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
    <Setter Property="ItemContainerStyle">
      <Setter.Value>
        <Style TargetType="ListBoxItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
          <Setter Property="Padding" Value="0"/>
          <Setter Property="FocusVisualStyle" Value="{StaticResource SW.FocusVisual}"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ListBoxItem">
                <Border x:Name="Chrome" Background="Transparent" CornerRadius="10"
                        Padding="{TemplateBinding Padding}">
                  <ContentPresenter/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#12161F"/>
                  </Trigger>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="Chrome" Property="Background" Value="#1A2030"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ═══════════════════════ Tooltip ═══════════════════════ -->

  <Style TargetType="ToolTip">
    <Setter Property="Background" Value="#1A1F2C"/>
    <Setter Property="Foreground" Value="{StaticResource SW.Text}"/>
    <Setter Property="BorderBrush" Value="{StaticResource SW.Stroke}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToolTip">
          <Border Background="{TemplateBinding Background}" BorderThickness="1"
                  BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="8" Padding="10,6">
            <ContentPresenter/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
