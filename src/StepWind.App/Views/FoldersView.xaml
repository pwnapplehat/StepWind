<UserControl x:Class="StepWind.App.Views.FoldersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <Grid Margin="28,4,28,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid>
      <StackPanel>
        <TextBlock Text="Protected folders" Style="{StaticResource SW.PageTitle}"/>
        <TextBlock Style="{StaticResource SW.PageSub}" Margin="0,4,0,0"
                   Text="Files in these folders get continuous version history — every save is kept, deduplicated and compressed, so you can go back in time."/>
      </StackPanel>
      <Button Style="{StaticResource SW.Button.Primary}" HorizontalAlignment="Right"
              VerticalAlignment="Top" Click="OnAddFolder">
        <StackPanel Orientation="Horizontal">
          <ui:SymbolIcon Symbol="Add24" FontSize="14"/>
          <TextBlock Text="Add folder" Margin="7,0,0,0"/>
        </StackPanel>
      </Button>
    </Grid>

    <!-- How it works strip -->
    <Border Grid.Row="1" Style="{StaticResource SW.CardStyle}" Margin="0,16,0,14" Padding="16,12">
      <StackPanel Orientation="Horizontal">
        <ui:SymbolIcon Symbol="Info24" FontSize="15" Foreground="{StaticResource SW.Cyan}"
                       VerticalAlignment="Top" Margin="0,2,0,0"/>
        <TextBlock FontSize="12" Foreground="{StaticResource SW.Text2}" Margin="10,0,0,0"
                   TextWrapping="Wrap" MaxWidth="760" HorizontalAlignment="Left">
          A version is captured a couple of seconds after a file settles. Identical re-saves
          are skipped, build junk and caches are excluded automatically, and tiered retention
          keeps the store small. Restores never overwrite your current file — the recovered
          version lands next to it.
        </TextBlock>
      </StackPanel>
    </Border>

    <!-- Folder cards -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding WatchedFolders}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource SW.CardStyle.Hover}" Width="330" Margin="0,0,14,14"
                    Padding="16,14">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="38" Height="38" CornerRadius="9" Background="{StaticResource SW.IndigoFaint}">
                  <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="18" Foreground="#9B9DF7"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding}" FontSize="12.5" FontWeight="Medium"
                             Foreground="{StaticResource SW.Text}" TextTrimming="CharacterEllipsis"
                             ToolTip="{Binding}"/>
                  <TextBlock Text="Watching, including subfolders" FontSize="11"
                             Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" Style="{StaticResource SW.Button.Ghost}" Padding="8,6"
                        VerticalAlignment="Center" Click="OnRemoveFolder"
                        ToolTip="Stop protecting this folder (existing history is kept)">
                  <ui:SymbolIcon Symbol="Dismiss24" FontSize="13"/>
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
