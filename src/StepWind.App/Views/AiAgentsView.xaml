<UserControl x:Class="StepWind.App.Views.AiAgentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:app="clr-namespace:StepWind.App">
  <Grid Margin="28,4,28,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid>
      <StackPanel>
        <TextBlock Text="AI agents" Style="{StaticResource SW.PageTitle}"/>
        <TextBlock Style="{StaticResource SW.PageSub}" Margin="0,4,0,0"
                   Text="Give AI coding tools a time machine: they can checkpoint a file before a risky edit, diff exactly what they changed, and restore — never delete."/>
      </StackPanel>
      <Button Style="{StaticResource SW.Button}" HorizontalAlignment="Right"
              VerticalAlignment="Top" Click="OnRescan" ToolTip="Re-scan this PC for AI tools">
        <StackPanel Orientation="Horizontal">
          <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14"/>
          <TextBlock Text="Re-scan" Margin="7,0,0,0"/>
        </StackPanel>
      </Button>
    </Grid>

    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto"
                  app:SmoothScroll.Enabled="True">
      <StackPanel>

        <!-- What the agent can and cannot do — the trust contract, stated up front.
             Grid (icon | *) rather than a horizontal StackPanel: the * column hands the text
             the REAL remaining width so it wraps instead of clipping at narrow window sizes. -->
        <Border Style="{StaticResource SW.CardStyle}" Padding="16,12" Margin="0,0,0,14">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="15" Foreground="{StaticResource SW.Ok}"
                           VerticalAlignment="Top" Margin="0,2,0,0"/>
            <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource SW.Text2}" Margin="10,0,0,0"
                       TextWrapping="Wrap" MaxWidth="820" HorizontalAlignment="Left">
              Connecting a tool adds StepWind's MCP server to that tool's config — merged in
              safely, with a backup of the file taken first and every change reversible with
              one click. The agent gets read + restore powers only: it can browse history,
              read old versions, diff, checkpoint, and restore (restores never overwrite).
              It can never delete history or change StepWind settings. Nothing runs in the
              background — the tool starts the server on demand.
            </TextBlock>
          </Grid>
        </Border>

        <!-- Detection summary -->
        <TextBlock Text="{Binding AgentsSummary}" FontSize="12" Foreground="{StaticResource SW.Text3}"
                   Margin="2,0,0,10"/>

        <!-- One card per supported AI tool -->
        <ItemsControl ItemsSource="{Binding Agents}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Width="356" Margin="0,0,14,14" Padding="16,14">
                <Border.Style>
                  <Style TargetType="Border" BasedOn="{StaticResource SW.CardStyle.Hover}">
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Detected}" Value="False">
                        <Setter Property="Opacity" Value="0.45"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tile: green when connected, indigo otherwise -->
                    <Border Width="38" Height="38" CornerRadius="9">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="{StaticResource SW.IndigoFaint}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Connected}" Value="True">
                              <Setter Property="Background" Value="{StaticResource SW.OkFaint}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <ui:SymbolIcon Symbol="Bot24" FontSize="19">
                        <ui:SymbolIcon.Style>
                          <Style TargetType="ui:SymbolIcon">
                            <Setter Property="Foreground" Value="#9B9DF7"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Connected}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SW.Ok}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </ui:SymbolIcon.Style>
                      </ui:SymbolIcon>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                 Foreground="{StaticResource SW.Text}"/>
                      <TextBlock Text="{Binding StatusText}" FontSize="11" Margin="0,3,0,0"
                                 TextWrapping="Wrap">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource SW.Text3}"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Connected}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SW.Ok}"/>
                              </DataTrigger>
                              <DataTrigger Binding="{Binding NeedsRepair}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SW.Warn}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </StackPanel>
                  </Grid>

                  <!-- Actions + config path -->
                  <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ConfigPath}" FontSize="10" VerticalAlignment="Center"
                               Foreground="{StaticResource SW.Text3}" FontFamily="{StaticResource SW.Font.Mono}"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding ConfigPath}" Margin="2,0,10,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <Button Style="{StaticResource SW.Button.Primary}" Content="Connect" Padding="14,5"
                              Visibility="{Binding ShowConnect, Converter={StaticResource BoolToVis}}"
                              Click="OnConnect"/>
                      <Button Style="{StaticResource SW.Button.Primary}" Content="Repair" Padding="14,5"
                              Visibility="{Binding ShowRepair, Converter={StaticResource BoolToVis}}"
                              ToolTip="Update the entry to point at this StepWind installation"
                              Click="OnConnect"/>
                      <Button Style="{StaticResource SW.Button.Ghost}" Content="Disconnect" Padding="10,5"
                              Margin="8,0,0,0"
                              Visibility="{Binding ShowDisconnect, Converter={StaticResource BoolToVis}}"
                              ToolTip="Remove StepWind from this tool's MCP config"
                              Click="OnDisconnect"/>
                    </StackPanel>
                  </Grid>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Manual setup: any other MCP client -->
        <TextBlock Text="Manual setup — any other MCP client" Style="{StaticResource SW.SectionLabel}"
                   Margin="2,10,0,8"/>
        <Border Style="{StaticResource SW.CardStyle}" Padding="16,13" MaxWidth="820"
                HorizontalAlignment="Left" Margin="0,0,0,8">
          <StackPanel>
            <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,0,0,10"
                       TextWrapping="Wrap"
                       Text="Using an AI tool that isn't listed above? Paste this into its MCP configuration — it's the standard mcpServers shape nearly every client understands."/>
            <Grid>
              <Border Background="{StaticResource SW.Inset}" CornerRadius="8" BorderThickness="1"
                      BorderBrush="{StaticResource SW.StrokeSoft}" Padding="12,10">
                <TextBox Text="{Binding McpConfigSnippet, Mode=OneWay}" IsReadOnly="True"
                         BorderThickness="0" Background="Transparent" Foreground="{StaticResource SW.Text2}"
                         FontFamily="{StaticResource SW.Font.Mono}" FontSize="11.5"
                         TextWrapping="Wrap" IsReadOnlyCaretVisible="True"/>
              </Border>
              <Button Style="{StaticResource SW.Button}" Content="Copy" Padding="12,5"
                      HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                      Click="OnCopyMcpConfig"/>
            </Grid>
            <TextBlock FontSize="11" Foreground="{StaticResource SW.Text3}" Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Text="Config backups: before StepWind edits any tool's config it saves a copy — Open backups shows them, newest first."/>
            <Button Style="{StaticResource SW.Button.Ghost}" Content="Open backups folder"
                    HorizontalAlignment="Left" Margin="0,8,0,0" Padding="10,5"
                    Click="OnOpenBackups"/>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
