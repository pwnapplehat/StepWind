<UserControl x:Class="StepWind.App.Views.FilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:app="clr-namespace:StepWind.App">
  <Grid Margin="28,4,28,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid>
      <StackPanel>
        <TextBlock Text="File versions" Style="{StaticResource SW.PageTitle}"/>
        <TextBlock Style="{StaticResource SW.PageSub}" Margin="0,4,0,0"
                   Text="Browse your protected folders, drill into any subfolder, and restore any past version — even after an overwrite or delete."/>
      </StackPanel>
      <Button Style="{StaticResource SW.Button}" HorizontalAlignment="Right" VerticalAlignment="Top"
              Click="OnBrowseFile">
        <StackPanel Orientation="Horizontal">
          <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
          <TextBlock Text="Open a file…" Margin="7,0,0,0"/>
        </StackPanel>
      </Button>
    </Grid>

    <Grid Grid.Row="1" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.15*"/>
        <ColumnDefinition Width="16"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: folder browser -->
      <Border Style="{StaticResource SW.CardStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Breadcrumb + up -->
          <Grid Margin="12,12,12,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource SW.Button.Ghost}" Padding="7,5" Margin="0,0,6,0"
                    Click="OnGoUp" IsEnabled="{Binding CanGoUp}" ToolTip="Up one folder">
              <ui:SymbolIcon Symbol="ArrowUp24" FontSize="14"/>
            </Button>
            <ItemsControl Grid.Column="1" ItemsSource="{Binding Breadcrumbs}" VerticalAlignment="Center">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource SW.Button.Ghost}" Padding="5,3" Click="OnCrumb"
                            Content="{Binding Label}" FontSize="12" Tag="{Binding Path}">
                      <Button.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource SW.Button.Ghost}"/>
                      </Button.Resources>
                    </Button>
                    <TextBlock Text="›" Foreground="{StaticResource SW.Text3}" VerticalAlignment="Center"
                               Margin="1,0" FontSize="13" Visibility="{Binding IsLast, Converter={StaticResource InverseBoolToVis}}"/>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>

          <!-- Search -->
          <Grid Grid.Row="1" Margin="12,0,12,10">
            <TextBox x:Name="SearchBox" Style="{StaticResource SW.TextBox}"
                     Text="{Binding BrowseSearch, UpdateSourceTrigger=PropertyChanged, Delay=200}"/>
            <TextBlock Text="Search this folder and everything under it…" FontSize="12.5" Margin="13,0,0,0"
                       VerticalAlignment="Center" IsHitTestVisible="False"
                       Foreground="{StaticResource SW.Text3}">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>

          <Grid Grid.Row="2">
            <ListBox x:Name="BrowseList" Style="{StaticResource SW.List}"
                     app:SmoothScroll.Enabled="True"
                     ItemsSource="{Binding BrowseEntries}" Padding="6,0,6,6"
                     PreviewMouseLeftButtonUp="OnEntryClick" KeyDown="OnEntryKey">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="10,7">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="8">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="{StaticResource SW.IndigoFaint}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                              <Setter Property="Background" Value="{StaticResource SW.CyanFaint}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>
                      <TextBlock Text="{Binding Glyph}" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#9B9DF7"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource SW.Cyan}"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Medium"
                                 Foreground="{StaticResource SW.Text}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Detail}" FontSize="11"
                                 Foreground="{StaticResource SW.Text3}" TextTrimming="CharacterEllipsis"
                                 Margin="0,2,0,0"/>
                    </StackPanel>
                    <ui:SymbolIcon Grid.Column="2" Symbol="ChevronRight24" FontSize="13"
                                   Foreground="{StaticResource SW.Text3}" VerticalAlignment="Center"
                                   Margin="6,0,4,0"
                                   Visibility="{Binding IsFolder, Converter={StaticResource BoolToVis}}"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20"
                        Visibility="{Binding BrowseIsEmpty, Converter={StaticResource BoolToVis}}">
              <ui:SymbolIcon Symbol="FolderOpen24" FontSize="30" Foreground="{StaticResource SW.Text3}"
                             HorizontalAlignment="Center"/>
              <TextBlock FontSize="12.5" Foreground="{StaticResource SW.Text2}" TextAlignment="Center"
                         Margin="0,10,0,0" TextWrapping="Wrap" MaxWidth="280">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="No saved versions here yet. Edit a file in a protected folder and it'll appear."/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding BrowseIsSearch}" Value="True">
                        <Setter Property="Text" Value="No files match your search in this folder."/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <!-- Right: version history of the picked file -->
      <Border Grid.Column="2" Style="{StaticResource SW.CardStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Margin="16,12,10,8">
            <TextBlock Text="Version history" Style="{StaticResource SW.SectionLabel}"
                       VerticalAlignment="Center"/>
            <Button Style="{StaticResource SW.Button.Ghost}" Padding="8,4" HorizontalAlignment="Right"
                    Click="OnDeleteFileHistory" ToolTip="Delete every saved version of this file"
                    Visibility="{Binding HasHistorySelection, Converter={StaticResource BoolToVis}}">
              <ui:SymbolIcon Symbol="Delete24" FontSize="13" Foreground="{StaticResource SW.Danger}"/>
            </Button>
          </Grid>
          <TextBlock Grid.Row="1" Text="{Binding HistoryTitle}" FontSize="11.5" Margin="16,0,16,10"
                     Foreground="{StaticResource SW.Text2}" TextWrapping="Wrap"/>
          <ListBox Grid.Row="2" Style="{StaticResource SW.List}" app:SmoothScroll.Enabled="True"
                   ItemsSource="{Binding History}" Padding="6,0,6,6">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="10,7">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding When}" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource SW.Text}"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource SW.Text3}" Margin="0,2,0,0">
                      <Run Text="{Binding SizeText, Mode=OneWay}"/><Run Text="  ·  "/><Run Text="{Binding Reason, Mode=OneWay}"/>
                    </TextBlock>
                  </StackPanel>
                  <Button Grid.Column="1" Style="{StaticResource SW.Button}" Content="Restore"
                          Padding="14,6" VerticalAlignment="Center" Click="OnRestore"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
