<UserControl x:Class="StepWind.App.Views.FilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <Grid Margin="28,4,28,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid>
      <StackPanel>
        <TextBlock Text="File versions" Style="{StaticResource SW.PageTitle}"/>
        <TextBlock Style="{StaticResource SW.PageSub}" Margin="0,4,0,0"
                   Text="Every save of every file in a protected folder is kept. Go back to any version — even after an overwrite or delete."/>
      </StackPanel>
      <Button Style="{StaticResource SW.Button}" HorizontalAlignment="Right" VerticalAlignment="Top"
              Click="OnBrowseFile">
        <StackPanel Orientation="Horizontal">
          <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/>
          <TextBlock Text="Browse a file…" Margin="7,0,0,0"/>
        </StackPanel>
      </Button>
    </Grid>

    <Grid Grid.Row="1" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="16"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: recently changed protected files -->
      <Border Style="{StaticResource SW.CardStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="Recently changed" Style="{StaticResource SW.SectionLabel}"
                     Margin="16,14,16,8"/>
          <Grid Grid.Row="1" Margin="12,0,12,10">
            <TextBox x:Name="SearchBox" Style="{StaticResource SW.TextBox}"
                     Text="{Binding RecentSearch, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Search protected files…" FontSize="12.5" Margin="13,0,0,0"
                       VerticalAlignment="Center" IsHitTestVisible="False"
                       Foreground="{StaticResource SW.Text3}">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Collapsed"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                      <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
          <ListBox x:Name="RecentList" Grid.Row="2" Style="{StaticResource SW.List}"
                   ItemsSource="{Binding RecentView}" Padding="6,0,6,6"
                   SelectionChanged="OnRecentFileSelected">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="10,7">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Border Width="34" Height="34" CornerRadius="8" Background="{StaticResource SW.IndigoFaint}">
                    <ui:SymbolIcon Symbol="Document24" FontSize="16" Foreground="#9B9DF7"/>
                  </Border>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource SW.Text}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Detail}" FontSize="11"
                               Foreground="{StaticResource SW.Text3}" TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Right: version history of the picked file -->
      <Border Grid.Column="2" Style="{StaticResource SW.CardStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Margin="16,12,10,8">
            <TextBlock Text="Version history" Style="{StaticResource SW.SectionLabel}"
                       VerticalAlignment="Center"/>
            <Button Style="{StaticResource SW.Button.Ghost}" Padding="8,4" HorizontalAlignment="Right"
                    Click="OnDeleteFileHistory" ToolTip="Delete every saved version of this file">
              <ui:SymbolIcon Symbol="Delete24" FontSize="13" Foreground="{StaticResource SW.Danger}"/>
            </Button>
          </Grid>
          <TextBlock Grid.Row="1" Text="{Binding HistoryTitle}" FontSize="11.5" Margin="16,0,16,10"
                     Foreground="{StaticResource SW.Text2}" TextWrapping="Wrap"/>
          <ListBox Grid.Row="2" Style="{StaticResource SW.List}" ItemsSource="{Binding History}"
                   Padding="6,0,6,6">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="10,7">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding When}" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource SW.Text}"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource SW.Text3}" Margin="0,2,0,0">
                      <Run Text="{Binding SizeText, Mode=OneWay}"/><Run Text="  ·  "/><Run Text="{Binding Reason, Mode=OneWay}"/>
                    </TextBlock>
                  </StackPanel>
                  <Button Grid.Column="1" Style="{StaticResource SW.Button}" Content="Restore"
                          Padding="14,6" VerticalAlignment="Center" Click="OnRestore"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
