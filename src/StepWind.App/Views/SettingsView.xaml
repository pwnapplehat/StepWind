<UserControl x:Class="StepWind.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:app="clr-namespace:StepWind.App">
  <Grid Margin="28,4,28,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="Settings" Style="{StaticResource SW.PageTitle}"/>
      <TextBlock Style="{StaticResource SW.PageSub}" Margin="0,4,0,0"
                 Text="StepWind is set-and-forget by design — there isn't much to configure."/>
    </StackPanel>

    <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto" app:SmoothScroll.Enabled="True">
      <StackPanel MaxWidth="720" HorizontalAlignment="Left">

        <TextBlock Text="Updates" Style="{StaticResource SW.SectionLabel}" Margin="2,0,0,8"/>
        <Border Style="{StaticResource SW.CardStyle}" Padding="16,13">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="Automatic silent updates" FontSize="13" FontWeight="Medium"
                         Foreground="{StaticResource SW.Text}"/>
              <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"
                         TextWrapping="Wrap"
                         Text="The background service checks GitHub daily, verifies each update's SHA-256, and installs it with zero prompts."/>
            </StackPanel>
            <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                             IsChecked="{Binding AutoUpdateEnabled}"/>
          </Grid>
        </Border>

        <TextBlock Text="Protection" Style="{StaticResource SW.SectionLabel}" Margin="2,18,0,8"/>
        <Border Style="{StaticResource SW.CardStyle}" Padding="16,13">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="Flight recorder" FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource SW.Text}"/>
                <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"
                           TextWrapping="Wrap"
                           Text="Records file operations on all NTFS drives for the timeline and one-click undo."/>
              </StackPanel>
              <Border Grid.Column="1" CornerRadius="6" Padding="9,3" VerticalAlignment="Center">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="#1AFB7185"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding FlightRecorderOn}" Value="True">
                        <Setter Property="Background" Value="#1A34D399"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <TextBlock FontSize="11" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Text" Value="Off"/>
                      <Setter Property="Foreground" Value="{StaticResource SW.Danger}"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding FlightRecorderOn}" Value="True">
                          <Setter Property="Text" Value="Active"/>
                          <Setter Property="Foreground" Value="{StaticResource SW.Ok}"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </Border>
            </Grid>

            <Rectangle Height="1" Fill="{StaticResource SW.StrokeSoft}" Margin="0,12"/>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="Encryption at rest" FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource SW.Text}"/>
                <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"
                           TextWrapping="Wrap"
                           Text="AES-256-GCM with a key sealed by Windows (machine scope) — a stolen or offline drive can't read your history. Toggling re-encodes existing versions in the background; everything stays restorable throughout. File contents are encrypted; the index of names and dates is not."/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                            Visibility="{Binding ReEncoding, Converter={StaticResource BoolToVis}}">
                  <Ellipse Width="7" Height="7" Fill="{StaticResource SW.Cyan}" VerticalAlignment="Center"/>
                  <TextBlock Text="Re-encoding your history in the background…" FontSize="11"
                             Foreground="{StaticResource SW.Cyan}" Margin="6,0,0,0"/>
                </StackPanel>
              </StackPanel>
              <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                               IsChecked="{Binding EncryptionOn}"/>
            </Grid>

            <Rectangle Height="1" Fill="{StaticResource SW.StrokeSoft}" Margin="0,12"/>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="History storage" FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource SW.Text}"/>
                <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"
                           TextWrapping="Wrap"
                           Text="Deduplicated and compressed — old versions are garbage-collected automatically per the retention rules below."/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding StorageText}" Margin="16,0,0,0"
                         FontFamily="{StaticResource SW.Font}" FontSize="14" FontWeight="SemiBold"
                         Foreground="{StaticResource SW.Cyan}" VerticalAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <TextBlock Text="Retention" Style="{StaticResource SW.SectionLabel}" Margin="2,18,0,8"/>
        <Border Style="{StaticResource SW.CardStyle}" Padding="16,13">
          <StackPanel>
            <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" TextWrapping="Wrap"
                       Text="How long versions are kept. Everything is kept for the first window, then thinned to hourly and daily as versions age."/>
            <UniformGrid Columns="5" Margin="0,10,0,0">
              <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Keep all (hours)" FontSize="11" Foreground="{StaticResource SW.Text2}"/>
                <TextBox Style="{StaticResource SW.TextBox}" Margin="0,5,0,0"
                         Text="{Binding RetentionKeepAllHours, UpdateSourceTrigger=PropertyChanged}"/>
              </StackPanel>
              <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Hourly (days)" FontSize="11" Foreground="{StaticResource SW.Text2}"/>
                <TextBox Style="{StaticResource SW.TextBox}" Margin="0,5,0,0"
                         Text="{Binding RetentionHourlyDays, UpdateSourceTrigger=PropertyChanged}"/>
              </StackPanel>
              <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Daily (days)" FontSize="11" Foreground="{StaticResource SW.Text2}"/>
                <TextBox Style="{StaticResource SW.TextBox}" Margin="0,5,0,0"
                         Text="{Binding RetentionDailyDays, UpdateSourceTrigger=PropertyChanged}"/>
              </StackPanel>
              <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Max age (days)" FontSize="11" Foreground="{StaticResource SW.Text2}"/>
                <TextBox Style="{StaticResource SW.TextBox}" Margin="0,5,0,0"
                         Text="{Binding RetentionMaxAgeDays, UpdateSourceTrigger=PropertyChanged}"/>
              </StackPanel>
              <StackPanel>
                <TextBlock Text="Max per file" FontSize="11" Foreground="{StaticResource SW.Text2}"/>
                <TextBox Style="{StaticResource SW.TextBox}" Margin="0,5,0,0"
                         Text="{Binding RetentionMaxVersionsPerFile, UpdateSourceTrigger=PropertyChanged}"/>
              </StackPanel>
            </UniformGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
              <Button Style="{StaticResource SW.Button}" Content="Run cleanup now" Click="OnRunRetention"
                      ToolTip="Apply the retention rules immediately instead of waiting for the daily pass"/>
              <Button Style="{StaticResource SW.Button.Primary}" Content="Apply" Margin="10,0,0,0"
                      MinWidth="90" Click="OnApplyRetention"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock Text="Data management" Style="{StaticResource SW.SectionLabel}" Margin="2,18,0,8"/>
        <Border Style="{StaticResource SW.CardStyle}" Padding="16,13">
          <StackPanel>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="Clean up unprotected history" FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource SW.Text}"/>
                <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"
                           TextWrapping="Wrap"
                           Text="Deletes saved versions belonging to folders you no longer protect."/>
              </StackPanel>
              <Button Grid.Column="1" Style="{StaticResource SW.Button}" Content="Clean up"
                      VerticalAlignment="Center" Click="OnPurgeUnprotected"/>
            </Grid>

            <Rectangle Height="1" Fill="{StaticResource SW.StrokeSoft}" Margin="0,12"/>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="Delete all history" FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource SW.Danger}"/>
                <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"
                           TextWrapping="Wrap"
                           Text="Permanently deletes every saved version of every file and frees the disk space. Your actual files are not touched."/>
              </StackPanel>
              <Button Grid.Column="1" Style="{StaticResource SW.Button.Danger}" Content="Delete all…"
                      VerticalAlignment="Center" Click="OnPurgeAll"/>
            </Grid>
          </StackPanel>
        </Border>

        <TextBlock Text="Shortcuts" Style="{StaticResource SW.SectionLabel}" Margin="2,18,0,8"/>
        <Border Style="{StaticResource SW.CardStyle}" Padding="16,13">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="Panic hotkey" FontSize="13" FontWeight="Medium"
                         Foreground="{StaticResource SW.Text}"/>
              <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"
                         Text="Opens StepWind from anywhere the moment something goes wrong."/>
            </StackPanel>
            <Border Grid.Column="1" CornerRadius="6" Padding="10,4" VerticalAlignment="Center"
                    Background="{StaticResource SW.Inset}" BorderThickness="1"
                    BorderBrush="{StaticResource SW.Stroke}">
              <TextBlock Text="Ctrl + Shift + Z" FontFamily="{StaticResource SW.Font.Mono}"
                         FontSize="11.5" Foreground="{StaticResource SW.Text}"/>
            </Border>
          </Grid>
        </Border>

        <TextBlock Text="About" Style="{StaticResource SW.SectionLabel}" Margin="2,18,0,8"/>
        <Border Style="{StaticResource SW.CardStyle}" Padding="16,13" Margin="0,0,0,8">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="StepWind" FontSize="13" FontWeight="Medium"
                           Foreground="{StaticResource SW.Text}"/>
                <TextBlock Text="{Binding AppVersion, StringFormat=v{0}}" FontSize="11.5"
                           Foreground="{StaticResource SW.Text3}" Margin="7,1,0,0"/>
              </StackPanel>
              <TextBlock FontSize="11.5" Foreground="{StaticResource SW.Text3}" Margin="0,3,0,0"
                         Text="Free · open source · 100% local · no cloud · no account · no telemetry"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource SW.Button.Ghost}" Content="stepwind.app"
                    Margin="0,0,6,0" Click="OnOpenSite"/>
            <Button Grid.Column="2" Style="{StaticResource SW.Button.Ghost}" Content="GitHub"
                    Click="OnOpenRepo"/>
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
