<Application x:Class="StepWind.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:StepWind.App"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- WPF-UI supplies accessible control plumbing (ToggleSwitch, SymbolIcon, window
             caption buttons); StepWind's own design system (Theme.xaml) paints everything. -->
        <ui:ThemesDictionary Theme="Dark"/>
        <ui:ControlsDictionary/>
        <ResourceDictionary Source="Theme.xaml"/>
      </ResourceDictionary.MergedDictionaries>

      <BooleanToVisibilityConverter x:Key="BoolToVis"/>
      <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
      <local:ViewVisibilityConverter x:Key="ViewVis"/>
      <local:KindBrushConverter x:Key="KindBrush"/>
      <local:KindBrushConverter x:Key="KindBrushFaint" Variant="Faint"/>
    </ResourceDictionary>
  </Application.Resources>
</Application>
