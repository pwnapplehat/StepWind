<Window x:Class="StepWind.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="StepWind" Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#07090D"
        Closing="OnClosing">
  <!-- Chromeless: the web layer draws ALL chrome. app-region CSS (via WebView2's
       IsNonClientRegionSupportEnabled) provides native drag / snap layouts / double-click
       maximize / system menu; the host keeps a 6px resize strip around the WebView. -->
  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0"
                  CornerRadius="0" UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>

  <Grid>
    <tb:TaskbarIcon x:Name="Tray" ToolTipText="StepWind — an undo button for your PC"
                    TrayMouseDoubleClick="OnTrayOpen">
      <tb:TaskbarIcon.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Open StepWind" Click="OnTrayOpen"/>
          <MenuItem Header="Oh no — show recent changes  (Ctrl+Shift+Z)" Click="OnOhNo"/>
          <Separator/>
          <MenuItem Header="Exit" Click="OnTrayExit"/>
        </ContextMenu>
      </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>

    <wv2:WebView2 x:Name="Web" DefaultBackgroundColor="#07090D"/>

    <!-- Fallback shown only if the WebView2 layer fails to start (missing/broken runtime).
         Without it a transient init failure left a permanently blank window. Protection keeps
         running in the service regardless; this just recovers the UI. -->
    <Border x:Name="WebFail" Visibility="Collapsed" Background="#07090D">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="460" Margin="24">
        <TextBlock Text="StepWind's display couldn't start" Foreground="#F2F4F8"
                   FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        <TextBlock x:Name="WebFailMsg" Foreground="#9AA4B2" TextWrapping="Wrap" Margin="0,10,0,0"
                   TextAlignment="Center" Text="The web view runtime didn't load."/>
        <TextBlock Foreground="#6B7280" TextWrapping="Wrap" Margin="0,10,0,0" TextAlignment="Center"
                   Text="Your files are still being protected by the background service — this only affects the window."/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
          <Button Content="Retry" Click="OnWebRetry" Padding="16,7" Margin="0,0,10,0"/>
          <Button Content="Install WebView2 runtime" Click="OnInstallRuntime" Padding="16,7"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</Window>
