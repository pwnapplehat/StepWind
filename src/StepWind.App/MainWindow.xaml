<ui:FluentWindow x:Class="StepWind.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:tb="http://www.hardcodet.net/taskbar"
                 Title="StepWind" Width="900" Height="640"
                 MinWidth="720" MinHeight="480"
                 WindowStartupLocation="CenterScreen"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True" WindowBackdropType="None"
                 Closing="OnClosing">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Taskbar-style smoke tint over the acrylic (65%): the wallpaper blur stays visible,
         but text and cards keep contrast on any wallpaper. Shown only when the acrylic
         backdrop actually applied (see OnSourceInitialized) — matches BitBroom / Rescue. -->
    <Border x:Name="SmokeTint" Grid.RowSpan="4" Background="#A60E1014" Visibility="Collapsed"/>

    <tb:TaskbarIcon x:Name="Tray" ToolTipText="StepWind — an undo button for your PC"
                    TrayMouseDoubleClick="OnTrayOpen">
      <tb:TaskbarIcon.ContextMenu>
        <ContextMenu>
          <MenuItem Header="Open StepWind" Click="OnTrayOpen"/>
          <MenuItem Header="Oh no — show recent changes  (Ctrl+Shift+Z)" Click="OnOhNo"/>
          <Separator/>
          <MenuItem Header="Exit" Click="OnTrayExit"/>
        </ContextMenu>
      </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>

    <ui:TitleBar Grid.Row="0">
      <ui:TitleBar.Header>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
          <Image Source="pack://application:,,,/Assets/icon.png" Width="22" Height="22"
                 RenderOptions.BitmapScalingMode="HighQuality"/>
          <TextBlock Text="StepWind" FontSize="12" VerticalAlignment="Center" Margin="9,0,0,0"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        </StackPanel>
      </ui:TitleBar.Header>
    </ui:TitleBar>

    <Border Grid.Row="1" Margin="16,6,16,0" CornerRadius="10" Padding="16,12"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,10,0">
          <Ellipse.Style>
            <Style TargetType="Ellipse">
              <Setter Property="Fill" Value="{StaticResource Brush.Danger}"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding ServiceUp}" Value="True">
                  <Setter Property="Fill" Value="{StaticResource Brush.Accent2}"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Ellipse.Style>
        </Ellipse>
        <TextBlock Grid.Column="1" Text="{Binding Status}" VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
        <ui:Button Grid.Column="2" Content="Refresh" Appearance="Secondary" Click="OnRefresh"/>
      </Grid>
    </Border>

    <!-- Protected-folders manager -->
    <Border Grid.Row="2" Margin="16,10,16,0" CornerRadius="10" Padding="14,10"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Protected folders" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
        <ItemsControl Grid.Column="1" ItemsSource="{Binding WatchedFolders}" VerticalAlignment="Center">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border CornerRadius="6" Margin="0,2,6,2" Padding="8,3"
                      Background="{DynamicResource ControlStrokeColorDefaultBrush}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="12"
                             TextTrimming="CharacterEllipsis" MaxWidth="320"/>
                  <ui:Button Padding="4,0" Margin="6,0,0,0" Appearance="Transparent" FontSize="11"
                             Content="✕" ToolTip="Stop protecting this folder" Click="OnRemoveFolder"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <ui:Button Grid.Column="2" Content="Add folder…" Appearance="Secondary" Click="OnAddFolder"/>
      </Grid>
    </Border>

    <!-- Two panes: operation timeline (flight recorder) + file version history -->
    <Grid Grid.Row="3" Margin="16,10,16,16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="360"/>
      </Grid.ColumnDefinitions>

      <!-- Timeline -->
      <Border CornerRadius="10" Padding="4,8"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Margin="14,4,14,8" FontWeight="SemiBold" Text="What just happened (all drives)"/>
          <ListBox Grid.Row="1" ItemsSource="{Binding Timeline}" BorderThickness="0" Background="Transparent"
                   HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="10,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <Border CornerRadius="5" Padding="6,2" VerticalAlignment="Center" HorizontalAlignment="Left"
                          Background="{DynamicResource ControlStrokeColorDefaultBrush}">
                    <TextBlock Text="{Binding Kind}" FontSize="11"/>
                  </Border>
                  <StackPanel Grid.Column="1" Margin="10,0">
                    <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource Brush.Muted}">
                      <Run Text="{Binding When}"/><Run Text="  ·  "/><Run Text="{Binding ByProcess}"/>
                    </TextBlock>
                  </StackPanel>
                  <ui:Button Grid.Column="2" Content="Undo" Appearance="Primary" FontSize="12" Padding="10,4"
                             VerticalAlignment="Center" Click="OnReverse"
                             Visibility="{Binding Reversible, Converter={StaticResource BoolToVis}}"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- Version history -->
      <Border Grid.Column="2" CornerRadius="10" Padding="4,8"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Margin="14,4,10,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="File version history" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <ui:Button Grid.Column="1" Content="Browse a file…" Appearance="Primary" FontSize="12"
                       Padding="10,4" Click="OnBrowseFile"/>
          </Grid>
          <TextBlock Grid.Row="1" Margin="14,0,10,6" FontSize="12" Foreground="{StaticResource Brush.Muted}"
                     TextWrapping="Wrap" x:Name="HistoryHint"
                     Text="Pick a recently-changed file below, or Browse to any file — then restore any saved version, even if it was overwritten or deleted."/>

          <!-- Recently changed protected files: click one to load its history (no picker needed). -->
          <ListBox Grid.Row="2" x:Name="RecentList" ItemsSource="{Binding RecentFiles}" BorderThickness="0"
                   Background="Transparent" MaxHeight="150" HorizontalContentAlignment="Stretch" Margin="0,0,0,4"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   SelectionChanged="OnRecentFileSelected">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Margin="8,4">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{StaticResource Brush.Muted}"
                             TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <ListBox Grid.Row="3" ItemsSource="{Binding History}" BorderThickness="0" Background="Transparent"
                   HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid Margin="10,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="{Binding When}"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource Brush.Muted}">
                      <Run Text="{Binding SizeText}"/><Run Text="  ·  "/><Run Text="{Binding Reason}"/>
                    </TextBlock>
                  </StackPanel>
                  <ui:Button Grid.Column="1" Content="Restore" Appearance="Secondary" FontSize="12" Padding="10,4"
                             VerticalAlignment="Center" Click="OnRestore"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</ui:FluentWindow>
